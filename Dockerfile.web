# syntax=docker/dockerfile:1

# ShopMaster web client — Next.js App Router (FE-01/02): staff (POS/kiosk/admin)
# and customer (QR/online) surfaces in one build.
#
# node:22-slim, pnpm via corepack, the whole monorepo copied in, a workspace install,
# then `next build`. The web app depends only on @shopmaster/shared, so no Prisma
# client generation is needed here.

FROM node:22-slim AS build
WORKDIR /app

# NEXT_PUBLIC_API_URL is inlined into the client bundle at BUILD time
# (apps/web/src/lib/api.ts), so it must be present as an ENV before `next build`,
# not merely at runtime. For a real deploy pass the browser-reachable API URL
# (e.g. https://api.yourdomain.com/api), including the /api prefix.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000/api
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

# pnpm via corepack, pinned to the version in package.json "packageManager".
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Copy the whole monorepo (workspace install needs every manifest + the lockfile).
COPY . .

# Deterministic install, then a production Next.js build.
RUN pnpm install --frozen-lockfile
RUN pnpm --filter @shopmaster/web build

# The web server listens on 3000 (apps/web "start" = `next start -p 3000`).
EXPOSE 3000

CMD ["pnpm", "--filter", "@shopmaster/web", "start"]
