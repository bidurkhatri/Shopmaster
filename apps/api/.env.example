# ShopMaster API — environment variables (example / template).
#
# Copy to apps/api/.env for local use, or provide these through your platform's
# secrets manager in staging/production (PLAT-14 — do NOT commit real values or
# paste them into a deploy dashboard by hand). Every value below is a safe
# placeholder, not a real secret.

# --- Auth (Auth-Flow) --------------------------------------------------------
# HS256 signing key for session JWTs (packages/core/src/auth.ts). Use a long,
# random, unguessable string; rotate it on suspicion of exposure.
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# --- Database (DB-02 / PLAT-05) ----------------------------------------------
# Prisma datasource URL (packages/db/prisma/schema.prisma + packages/db/src/index.ts).
# The repo ships with SQLite for a self-contained run; production uses managed
# Postgres (flip the schema datasource provider to "postgresql" — the schema is
# Postgres-portable by design).
#
#   SQLite (default provider):   file:/data/shopmaster.db
#   Postgres (production):       postgresql://USER:PASSWORD@HOST:5432/shopmaster?schema=public&sslmode=require
#
# A relative SQLite path (e.g. file:./dev.db) is normalised against packages/db/prisma
# at runtime; an absolute file: path or a postgresql:// URL is passed through as-is.
DATABASE_URL=file:/data/shopmaster.db

# --- HTTP --------------------------------------------------------------------
# Port the API listens on (apps/api/src/index.ts → API_PORT ?? PORT ?? 4000).
API_PORT=4000

# --- Optional ----------------------------------------------------------------
# Set to "1" to log Prisma queries (packages/db/src/index.ts). Leave off in prod.
# PRISMA_LOG=0
# Set by the container image in production; affects Prisma client caching only.
# NODE_ENV=production
