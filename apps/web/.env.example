# ShopMaster web — environment variables (example / template).
#
# Copy to apps/web/.env.local for local development, or pass at BUILD time for
# containers (see Dockerfile.web / docker-compose.yml). Every value is a safe
# placeholder, not a real secret.
#
# IMPORTANT: NEXT_PUBLIC_* values are inlined into the client bundle at BUILD time,
# not read at runtime (apps/web/src/lib/api.ts). Set this before `next build`;
# changing it later requires rebuilding the web image.

# Base URL of the ShopMaster API, INCLUDING the trailing /api prefix. This is the
# URL the user's browser calls, so it must be reachable from the browser (not an
# internal container hostname).
#   Local dev:    http://localhost:4000/api
#   Production:   https://api.yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
